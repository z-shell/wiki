[4.399406, "o", "\u001b[K\r\r\n\u001b[1m\u001b[30m# This is an example code that is diverse and allows to test a theme\u001b[0m\u001b[39m\u001b[K\r\r\ntext=\u001b[38;5;150m\"An example quite long string \u001b[38;5;110m$with\u001b[39m\u001b[38;5;150m variable in it\"\u001b[39m\u001b[K\r\r\n\u001b[38;5;180mlocal\u001b[39m param1=\u001b[38;5;150m\"text \u001b[38;5;110m$variable\u001b[39m\u001b[38;5;150m\"\u001b[39m param2=\u001b[38;5;150m'other $variable'\u001b[39m\u001b[K\r\r\nmath=\u001b[38;5;110m$\u001b[39m\u001b[38;5;150m((\u001b[39m \u001b[38;5;166m10\u001b[39m + \u001b[31mHISTSIZ\u001b[39m + \u001b[1m\u001b[34mHISTSIZE\u001b[0m\u001b[39m + \u001b[38;5;110m$SAVEHIST\u001b[39m \u001b[38;5;150m))\u001b[39m size=\u001b[38;5;110m$\u001b[39m\u001b[38;5;150m((\u001b[39m \u001b[38;5;166m0\u001b[39m \u001b[38;5;150m))\u001b[39m\u001b[K\r\r\n\u001b[K\r\r\n\u001b[38;5;150mfor\u001b[39m \u001b[38;5;180m((\u001b[39m ii \u001b[38;5;150m=\u001b[39m \u001b[38;5;150m1\u001b[39m\u001b[38;5;109m;\u001b[39m ii \u001b[38;5;150m<=\u001b[39m size\u001b[38;5;109m;\u001b[39m \u001b[38;5;150m++\u001b[39m ii \u001b[38;5;180m))\u001b[39m; \u001b[38;5;150mdo\u001b[39m\u001b[K\r\r\n    \u001b[38;5;150mif\u001b[39m \u001b[38;5;180m[[\u001b[39m \u001b[38;5;150m\"\u001b[38;5;110m${cmds[ii]}\u001b[39m\u001b[38;5;150m string\"\u001b[39m \u001b[38;5;166m=\u001b[39m \u001b[38;5;150m\"| string\"\u001b[39m \u001b[38;5;180m]]\u001b[39m\u001b[K\r\r\n    \u001b[38;5;150mthen\u001b[39m\u001b[K\r\r\n        sidx=\u001b[38;5;110m$\u001b[39m\u001b"]
