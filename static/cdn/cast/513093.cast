[29.186377, "o", "30mo\u001b[1m\u001b[30ms\u001b[1m\u001b[30mi\u001b[1m\u001b[30mn\u001b[1m\u001b[30mg\u001b[1m\u001b[30m \u001b[1m\u001b[30mc\u001b[1m\u001b[30mm\u001b[1m\u001b[30md\u001b[1m\u001b[30m-\u001b[1m\u001b[30ms\u001b[1m\u001b[30mu\u001b[1m\u001b[30mb\u001b[1m\u001b[30ms\u001b[1m\u001b[30mt\u001b[0m\u001b[39m\u001b[1B\u001b[65D\u001b[1m\u001b[32m}\u001b[0m\u001b[39m\u001b[1B\b\b\b\b\b\u001b[38;5;186mf\u001b[38;5;186mi\u001b[39m\u001b[1B\r\u001b[38;5;186md\u001b[38;5;186mo\u001b[38;5;186mn\u001b[38;5;186me\u001b[39m\u001b[1B\r"]
