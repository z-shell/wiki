[29.436084, "o", "\u001b[K\r\r\n\u001b[1m\u001b[30m# This is an example code that is diverse and allows to test a theme\u001b[0m\u001b[39m\u001b[K\r\r\ntext=\u001b[38;5;186m\"An example quite long string \u001b[38;5;65m$with\u001b[39m\u001b[38;5;186m variable in it\"\u001b[39m\u001b[K\r\r\n\u001b[38;5;101mlocal\u001b[39m param1=\u001b[38;5;186m\"text \u001b[38;5;65m$variable\u001b[39m\u001b[38;5;186m\"\u001b[39m param2=\u001b[38;5;186m'other $variable'\u001b[39m\u001b[K\r\r\nmath=\u001b[38;5;65m$\u001b[39m\u001b[38;5;186m((\u001b[39m \u001b[38;5;107m10\u001b[39m + \u001b[38;5;124mHISTSIZ\u001b[39m + \u001b[38;5;114mHISTSIZE\u001b[39m + \u001b[38;5;65m$SAVEHIST\u001b[39m \u001b[38;5;186m))\u001b[39m size=\u001b[38;5;65m$\u001b[39m\u001b[38;5;186m((\u001b[39m \u001b[38;5;107m0\u001b[39m \u001b[38;5;186m))\u001b[39m\u001b[K\r\r\n\u001b[K\r\r\n\u001b[38;5;186mfor\u001b[39m \u001b[38;5;101m((\u001b[39m ii \u001b[38;5;186m=\u001b[39m \u001b[38;5;107m1\u001b[39m\u001b[38;5;109m;\u001b[39m ii \u001b[38;5;186m<=\u001b[39m size\u001b[38;5;109m;\u001b[39m \u001b[38;5;186m++\u001b[39m ii \u001b[38;5;101m))\u001b[39m; \u001b[38;5;186mdo\u001b[39m\u001b[K\r\r\n    \u001b[38;5;186mif\u001b[39m \u001b[38;5;101m[[\u001b[39m \u001b[38;5;186m\"\u001b[38;5;65m${cmds[ii]}\u001b[39m\u001b[38;5;186m string\"\u001b[39m \u001b[38;5;107m=\u001b[39m \u001b[38;5;186m\"| string\"\u001b[39m \u001b[38;5;101m]]\u001b[39m\u001b[K\r\r\n    \u001b[38;5;186mthen\u001b[39m\u001b[K\r\r\n        sidx=\u001b[38;5;65m$\u001b[39m\u001b[1m"]
