[4.399811, "o", "\u001b[0m\u001b[39mbuffer\u001b[1m\u001b[33m[\u001b[0m\u001b[39m\u001b[1m\u001b[36m(\u001b[0m\u001b[39min:ii:\u001b[1m\u001b[36m)\u001b[0m\u001b[39m\u001b[38;5;110m\\$\u001b[39m\\(?#\u001b[1m\u001b[36m[\u001b[0m\u001b[39m^\\\\\\\\\u001b[1m\u001b[36m]\u001b[0m\u001b[39m\\)\u001b[1m\u001b[33m]\u001b[0m\u001b[39m\u001b[1m\u001b[32m}\u001b[0m\u001b[39m \u001b[1m\u001b[30m# find opening cmd-subst\u001b[0m\u001b[39m\u001b[K\r\r\n        \u001b[38;5;150m((\u001b[39m \u001b[1m\u001b[34msidx\u001b[0m\u001b[39m <= \u001b[31mlen\u001b[39m \u001b[38;5;150m))\u001b[39m && \u001b[1m\u001b[32m{\u001b[0m\u001b[39m\u001b[K\r\r\n            eidx=\u001b[38;5;110m$\u001b[39m\u001b[1m\u001b[33m{\u001b[0m\u001b[39mbuffer\u001b[1m\u001b[36m[\u001b[0m\u001b[39m\u001b[1m\u001b[32m(\u001b[0m\u001b[39mb:sidx:ii\u001b[1m\u001b[32m)\u001b[0m\u001b[39m\u001b[1m\u001b[32m[\u001b[0m\u001b[39m^\\\\\\\\\u001b[1m\u001b[32m]\u001b[0m\u001b[39m\\)\u001b[1m\u001b[36m]\u001b[0m\u001b[39m\u001b[1m\u001b[33m}\u001b[0m\u001b[39m \u001b[1m\u001b[30m# find closing cmd-subst\u001b[0m\u001b[39m\u001b[K\r\r\n        \u001b[1m\u001b[32m}\u001b[0m\u001b[39m\u001b[K\r\r\n    \u001b[38;5;150mfi\u001b[39m\u001b[K\r\r\n\u001b[38;5;150mdone\u001b[39m\u001b[K\r\r\n\u001b[K\r\r\n\u001b[K\u001b[3A"]
