[3.781184, "o", "\u001b[38;5;150mt\u001b[38;5;150mh\u001b[38;5;150me\u001b[38;5;150mn\u001b[39m\u001b[1B\u001b[5C\u001b[38;5;110m$\u001b[39m\u001b[1m\u001b[32m{\u001b[0m\u001b[39m\u001b[6C\u001b[1m\u001b[33m[\u001b[0m\u001b[39m\u001b[1m\u001b[36m(\u001b[0m\u001b[39m\u001b[6C\u001b[1m\u001b[36m)\u001b[0m\u001b[39m\u001b[38;5;110m\\\u001b[38;5;110m$\u001b[39m\u001b[4C\u001b[1m\u001b[36m[\u001b[0m\u001b[39m\u001b[5C\u001b[1m\u001b[36m]\u001b[0m\u001b[39m\u001b[2C\u001b[1m\u001b[33m]\u001b[0m\u001b[39m\u001b[1m\u001b[32m}\u001b[0m\u001b[39m \u001b[1m\u001b[30m#\u001b[1m\u001b[30m \u001b[1m\u001b[30mf\u001b[1m\u001b[30mi\u001b[1m\u001b[30mn\u001b[1m\u001b[30md\u001b[1m\u001b[30m \u001b[1m\u001b[30mo\u001b[1m\u001b[30mp\u001b[1m\u001b[30me\u001b[1m\u001b[30mn\u001b[1m\u001b[30mi\u001b[1m\u001b[30mn\u001b[1m\u001b[30mg\u001b[1m\u001b[30m \u001b[1m\u001b[30mc\u001b[1m\u001b[30mm\u001b[1m\u001b[30md\u001b[1m\u001b[30m-\u001b[1m\u001b[30ms\u001b[1m\u001b[30mu\u001b[1m\u001b[30mb\u001b[1m\u001b[30ms\u001b[1m\u001b[30mt\u001b[0m\u001b[39m\u001b[1B\u001b[64D\u001b[38;5;150m(\u001b[38;5;150m(\u001b[39m \u001b[1m\u001b[34ms\u001b[1m\u001b[34mi\u001b[1m\u001b[34md\u001b[1m\u001b[34mx\u001b[0m\u001b[39m\u001b[4C\u001b[31ml\u001b[31me\u001b[31mn\u001b[39m \u001b[38;5;150m)\u001b[38;5;150m)\u001b[39m\u001b[4C\u001b[1m\u001b[32m{\u001b[0m\u001b[39m\u001b[1B\u001b[13D\u001b[38;5;110m$\u001b[39m\u001b[1m\u001b[33m{\u001b[0m\u001b[39m\u001b[6C\u001b[1m\u001b[36m[\u001b[0m\u001b[39m\u001b[1m\u001b[32m(\u001b[0m\u001b[39m\u001b[9C\u001b[1m\u001b[32m)\u001b[0m\u001b[39m\u001b[1m\u001b[32m[\u001b[0m\u001b[39m\u001b[5C\u001b[1m\u001b[32m]\u001b[0m\u001b[39m\u001b[2C\u001b[1m\u001b[36m]\u001b[0m\u001b[39m\u001b[1m\u001b[33m}\u001b[0m\u001b[39m \u001b[1m\u001b[30m#\u001b[1m\u001b[30m \u001b[1m\u001b[30mf\u001b[1m\u001b[30mi\u001b[1m\u001b[30mn\u001b[1m\u001b[30md\u001b[1m\u001b[30m \u001b[1m\u001b[30mc\u001b[1m\u001b[30ml\u001b[1m\u001b[30mo\u001b[1m\u001b[30ms\u001b[1m\u001b[30mi\u001b[1m\u001b