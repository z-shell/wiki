[28.708152, "o", "\u001b[K\r\r\n# This is an example code that is diverse and allows to test a theme\u001b[K\r\r\ntext=\"An example quite long string $with variable in it\"\u001b[K\r\r\nlocal param1=\"text $variable\" param2='other $variable'\u001b[K\r\r\nmath=$(( 10 + HISTSIZ + HISTSIZE + $SAVEHIST )) size=$(( 0 ))\u001b[K\r\r\n\u001b[K\r\r\nfor (( ii = 1; ii <= size; ++ ii )); do\u001b[K\r\r\n    if [[ \"${cmds[ii]} string\" = \"| string\" ]]\u001b[K\r\r\n    then\u001b[K\r\r\n        sidx=${buffer[(in:ii:)\\$\\(?#[^\\\\\\\\]\\)]} # find opening cmd-subst\u001b[K\r\r\n        (( sidx <= len )) && {\u001b[K\r\r\n            eidx=${buffer[(b:sidx:ii)[^\\\\\\\\]\\)]} # find closing cmd-subst\u001b[K\r\r\n        }\u001b[K\r\r\n    fi\u001b[K\r\r\ndone\u001b[K\r\r\n\u001b[K\r\r\n\u001b[K\u001b[?2004h\u001b[K"]
