# Security headers for all pages
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: document-domain=()
  X-Frame-Options: SAMEORIGIN
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' kit.fontawesome.com ka-f.fontawesome.com static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: raw.githubusercontent.com api.github.com github.com avatars.githubusercontent.com; font-src 'self'; frame-src ghbtns.com; connect-src 'self' ka-f.fontawesome.com static.cloudflareinsights.com api.github.com *.algolia.net *.algolianet.com raw.githubusercontent.com; worker-src 'self'

# CDN font binaries — fingerprinted, cache immutably
/cdn/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Robots-Tag: nosnippet, noindex

# CDN recordings — fingerprinted, cache immutably
/cdn/cast/*.cast
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Robots-Tag: nosnippet, noindex

# CDN stylesheets — not fingerprinted, allow revalidation
/cdn/*.css
  Cache-Control: public, max-age=86400
  Access-Control-Allow-Origin: *
  X-Robots-Tag: nosnippet, noindex

# Fingerprinted build assets — cache aggressively
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Robots-Tag: nosnippet, noindex

# Static images — cache aggressively
/img/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  X-Robots-Tag: nosnippet, noindex

# Prevent *.pages.dev production URL from being indexed
https://:project.pages.dev/*
  X-Robots-Tag: noindex

# Prevent preview deployment URLs from being indexed
https://:version.:project.pages.dev/*
  X-Robots-Tag: noindex
