{
  "name": "wiki",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build": "docusaurus build",
    "build:en": "docusaurus build --locale en",
    "clean": "pnpm exec rm -rf node_modules build .docusaurus .wrangler  pnpm-lock.yaml",
    "clear": "docusaurus clear",
    "crowdin:check": "crowdin lint && crowdin status",
    "crowdin:sync": "docusaurus write-translations && crowdin upload && crowdin download",
    "crowdin:upload": "pnpm crowdin upload sources --delete-obsolete",
    "deploy": "docusaurus deploy",
    "preinstall": "npx only-allow pnpm",
    "lint": "trunk check",
    "lint:all": "trunk check --all",
    "lint:fix": "trunk check --fix",
    "lint:links": "trunk check --filter lychee",
    "lint:links:all": "trunk check --all --filter lychee",
    "lint:links:refresh": "trunk check --all --filter lychee --cache=false",
    "project-health": "pnpm lint && pnpm build:en",
    "serve": "docusaurus serve",
    "start": "docusaurus start",
    "start:cf": "wrangler pages dev build --remote",
    "swizzle": "docusaurus swizzle",
    "validate:frontmatter": "node scripts/validate-frontmatter.mjs",
    "write-docs-version": "docusaurus docs:version",
    "write-heading-ids": "docusaurus write-heading-ids",
    "write-translations": "docusaurus write-translations"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/faster": "3.10.0",
    "@docusaurus/plugin-ideal-image": "3.10.0",
    "@docusaurus/plugin-pwa": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@mdx-js/react": "3.1.1",
    "asciinema-player": "3.15.1",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260423.1",
    "@crowdin/cli": "4.14.1",
    "@docusaurus/eslint-plugin": "3.10.0",
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "stylelint": "17.8.0",
    "stylelint-color-format": "1.1.0",
    "stylelint-config-css-modules": "4.6.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  }
}
