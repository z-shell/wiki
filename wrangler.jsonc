{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zsh",
  "compatibility_flags": ["nodejs_compat"],
  "compatibility_date": "2026-04-28",
  "assets": {
    "directory": "./build"
  },
  "r2_buckets": [
    {
      "binding": "ASSETS_BUCKET",
      "bucket_name": "r2-store"
    }
  ]
}
