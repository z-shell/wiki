# Global defaults: Auto-detect text files and perform LF normalization
* text=auto eol=lf

# Source Code
*.js      text diff=javascript
*.cjs     text diff=javascript
*.mjs     text diff=javascript
*.jsx     text diff=javascript
*.ts      text diff=typescript
*.tsx     text diff=typescript
*.css     text diff=css
*.scss    text diff=css

# Documentation (Docusaurus)
*.md      text diff=markdown
*.mdx     text diff=markdown
*.faster  text

# Shell & Zsh (Force LF for scripts)
*.sh      text eol=lf
*.bash    text eol=lf
*.zsh     text eol=lf
*.fish    text eol=lf

# Configuration & Data
*.json    text
*.yaml    text
*.yml     text
*.toml    text
*.xml     text
*.lock    text -diff
pnpm-lock.yaml text -diff

# Static Assets & Graphics
*.png     binary
*.jpg     binary
*.jpeg    binary
*.webp    binary
*.gif     binary
*.ico     binary
*.svg     binary
*.pdf     binary

# Fonts
*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary
*.eot     binary

# Archives
*.zip     binary
*.tar     binary
*.gz      binary
*.7z      binary

# Windows specific
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Git Meta
.gitattributes export-ignore
.gitignore     export-ignore
.gitkeep       export-ignore

# Linguist Overrides
# Mark i18n content as documentation
i18n/** linguist-documentation
# Mark build artifacts as generated
build/** linguist-generated
.docusaurus/** linguist-generated
