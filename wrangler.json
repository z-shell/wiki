{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wiki",
  "pages_build_output_dir": "build",
  "compatibility_date": "2026-04-19",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": {
      "head_sampling_rate": 1
    }
  },
  "r2_buckets": [
    {
      "binding": "ASSETS_BUCKET",
      "bucket_name": "r2-store"
    }
  ]
}
